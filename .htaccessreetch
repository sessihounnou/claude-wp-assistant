# ============================================================
# 1. OPTIONS GLOBALES
# ============================================================

Options -Indexes


# ============================================================
# 2. PROTECTION DES FICHIERS SENSIBLES
# ============================================================

# Bloquer l'accès aux fichiers .ht*
<FilesMatch "^\.ht">
    Order allow,deny
    Deny from all
    Satisfy All
</FilesMatch>

# Bloquer les fichiers sensibles WordPress
<FilesMatch "(wp-config\.php|wp-config-sample\.php|readme\.html|license\.txt|\.env|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquer les fichiers de log et backup
<FilesMatch "\.(log|bak|backup|sql|swp|orig)$">
    Order allow,deny
    Deny from all
</FilesMatch>


# ============================================================
# 3. BLOCAGE DE xmlrpc.php
# ============================================================

<Files xmlrpc.php>
    Order Deny,Allow
    Deny from all
</Files>


# ============================================================
# 4. PROTECTION wp-login.php (optionnel — IP fixe requise)
# ============================================================
# Décommentez et remplacez YOUR_IP par votre IP fixe :
#
# <Files wp-login.php>
#     Order deny,allow
#     Deny from all
#     Allow from YOUR_IP
# </Files>


# ============================================================
# 5. PROTECTION CONTRE LES INJECTIONS & ATTAQUES
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Blocage injections via query string
    RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} base64_encode.*\(.*\) [NC,OR]
    RewriteCond %{QUERY_STRING} (<|%3C)([^s]*s)+cript.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (\|%7C) [NC]
    RewriteRule .* - [F,L]

    # Blocage User-Agents malveillants
    RewriteCond %{HTTP_USER_AGENT} (libwww-perl|nikto|sqlmap|acunetix|nessus|masscan|zgrab) [NC]
    RewriteRule .* - [F,L]

    # Anti-hotlinking médias (domaine reetch.ca)
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?reetch\.ca [NC]
    RewriteRule \.(gif|jpg|jpeg|png|svg|webp|avif|mp4|webm)$ - [F,L]

    # Bloquer PHP dans uploads
    # Exclut wp-admin pour autoriser installation plugins/thèmes/médias
    RewriteCond %{REQUEST_URI} !^/wp-admin/ [NC]
    RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$
    RewriteRule ^wp-content/uploads/.*\.php$ - [F,L]
</IfModule>


